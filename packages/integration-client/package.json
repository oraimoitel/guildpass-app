{
  "name": "@guildpass/integration-client",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Typed client for GuildPass core API for integrations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Adamantine-guild/guildpass-app.git",
    "directory": "packages/integration-client"
  },
  "homepage": "https://github.com/Adamantine-guild/guildpass-app/tree/main/packages/integration-client",
  "bugs": {
    "url": "https://github.com/Adamantine-guild/guildpass-app/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "license": "MIT"
}
