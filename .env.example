# GuildPass Integrations — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── Discord Bot ────────────────────────────────────────────────────────────────
# Bot token from the Discord Developer Portal
DISCORD_TOKEN=

# Application/Client ID from the Discord Developer Portal
DISCORD_CLIENT_ID=

# The Discord server (guild) ID to register commands for during development
DISCORD_GUILD_ID=

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Activity feed polling interval in milliseconds (default: 15000 = 15 s)
NEXT_PUBLIC_ACTIVITY_REFRESH_MS=15000

# Webhook activity idempotency storage.
# Use the default in-memory mode for local mock dashboards.
# Set ACTIVITY_STORAGE_MODE=file to persist webhook IDs across local restarts.
ACTIVITY_STORAGE_MODE=memory
ACTIVITY_STORAGE_DIR=.guildpass-activity

# ── GuildPass Core API ─────────────────────────────────────────────────────────
# Base URL of the running guildpass-core access-api
GUILD_PASS_CORE_URL=http://localhost:3000

# Optional API key if core is running with auth enabled
GUILD_PASS_CORE_API_KEY=

# Incoming GuildPass webhook secret.
WEBHOOK_SECRET=

# ── Blockchain Indexer ────────────────────────────────────────────────────────
# EVM RPC URL
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key

# Membership Contract Address
MEMBERSHIP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Confirmation depth for reorg safety (number of blocks)
INDEXER_CONFIRMATION_DEPTH=10

# Starting block for the indexer
INDEXER_START_BLOCK=0

# Database URL for access-api (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/guildpass?schema=public

# ── Discord Role IDs ──────────────────────────────────────────────────────────
# Role IDs from your Discord server — used by the bot to assign roles
DISCORD_ROLE_ADMIN=
DISCORD_ROLE_MEMBER=
DISCORD_ROLE_CONTRIBUTOR=

# Optional: Client Secret for OAuth2 flows (e.g., if adding login functionality)
# DISCORD_CLIENT_SECRET=