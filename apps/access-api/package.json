{
  "name": "@guildpass/access-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GuildPass Access API and Event Indexer",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@guildpass/contracts": "workspace:*",
    "@prisma/client": "^5.15.0",
    "viem": "^2.13.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "prisma": "^5.15.0",
    "tsx": "^4.19.2",
    "@types/node": "^20.17.6",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
